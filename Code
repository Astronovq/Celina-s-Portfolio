  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Quicksand', sans-serif;
      background: #fafaff;
      color: #222;
      line-height: 1.6;
    }

    .container {
      width: 90%;
      max-width: 900px;
      margin: 0 auto;
    }

    header {
      background: #5a6fd8;
      color: white;
      padding: 1rem 0;
    }
    header .container {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    nav a {
      color: white;
      text-decoration: none;
      margin-left: 1.2rem;
      font-weight: 600;
      transition: all 0.3s ease;
    }
    nav a:hover {
      background-color: #3f4ca3;
      padding: 0.3rem 0.6rem;
      border-radius: 20px;
    }

    .hero {
      background: #5a6fd8;
      color: white;
      text-align: center;
      padding: 4rem 0 3rem 0;
    }
    .hero h1 {
      font-size: 2.5rem;
      margin-bottom: 0.5rem;
    }
    .hero .btn {
      display: inline-block;
      background: white;
      color: #5a6fd8;
      padding: 0.5rem 1.2rem;
      border-radius: 25px;
      text-decoration: none;
      font-weight: 600;
      margin-top: 1rem;
      transition: 0.3s ease;
    }
    .hero .btn:hover {
      transform: scale(1.05);
      background: #e0e4ff;
    }

    section {
      padding: 3rem 0;
      border-bottom: 1px solid #ddd;
    }
    h2 {
      text-align: center;
      margin-bottom: 2rem;
      font-size: 2rem;
    }

    .about-content {
      display: flex;
      gap: 1.5rem;
      flex-wrap: wrap;
      justify-content: center;
    }
    .about-card {
      background: white;
      padding: 1rem 1.5rem;
      border-radius: 15px;
      box-shadow: 2px 2px 8px rgba(0,0,0,0.05);
      text-align: center;
      width: 180px;
      transition: 0.3s ease;
    }
    .about-card:hover {
      transform: translateY(-5px);
      box-shadow: 4px 4px 12px rgba(0,0,0,0.1);
    }
    .about-card i {
      font-size: 2rem;
      color: #5a6fd8;
      margin-bottom: 0.5rem;
    }

    .skills-list {
      display: flex;
      flex-wrap: wrap;
      gap: 2rem;
      justify-content: center;
    }
    .skill-category {
      background: white;
      padding: 1.5rem;
      border-radius: 15px;
      width: 250px;
    }
    .skill-category h3 {
      color: #5a6fd8;
      margin-bottom: 0.8rem;
    }
    .skill-category ul {
      list-style-type: none;
    }
    .skill-category li {
      margin-bottom: 0.4rem;
    }
    .skill-category li i {
      color: #5a6fd8;
      width: 20px;
    }

    .project {
      background: #f2f2ff;
      padding: 1.5rem;
      margin-bottom: 1.5rem;
      border-radius: 10px;
      transition: 0.3s ease;
    }
    .project:hover {
      background: #e5e9ff;
      transform: scale(1.01);
    }
    .project h3 {
      color: #5a6fd8;
    }
    .project a {
      display: inline-block;
      margin-top: 0.8rem;
      color: #5a6fd8;
      font-weight: 600;
      text-decoration: none;
      border: 1px solid #5a6fd8;
      padding: 0.3rem 1rem;
      border-radius: 20px;
      transition: 0.3s ease;
    }
    .project a:hover {
      background: #5a6fd8;
      color: white;
    }

    .contact-links {
      display: flex;
      flex-wrap: wrap;
      gap: 1.5rem;
      justify-content: center;
    }
    .contact-links a {
      background: white;
      padding: 0.8rem 1.5rem;
      border-radius: 30px;
      text-decoration: none;
      color: #222;
      font-weight: 500;
      box-shadow: 2px 2px 6px rgba(0,0,0,0.05);
      transition: 0.3s ease;
    }
    .contact-links a:hover {
      background: #5a6fd8;
      color: white;
      transform: scale(1.05);
    }
    .contact-links i {
      margin-right: 0.5rem;
      color: #5a6fd8;
    }
    .contact-links a:hover i {
      color: white;
    }

    footer {
      background: #333;
      color: white;
      text-align: center;
      padding: 1.5rem 0;
      margin-top: 2rem;
    }
  </style>
