  .skill-card { background: white; padding: 20px; width: 250px; border-radius: 10px; }
  .skill-card h3 { margin-bottom: 10px; color: #6a8cff; }
  .skill-card ul { list-style: none; }
  .skill-card li { margin-bottom: 5px; }

  /* Experience */
  .timeline { padding-left: 10px; border-left: 3px solid #6a8cff; }
  .exp-item { margin-bottom: 20px; }
  .exp-card { background: white; padding: 15px; border-radius: 10px; }
  .exp-title { font-weight: 600; margin-bottom: 5px; }
